APP_NAME="Icerik Topic"
APP_INSTALLED=false
APP_ENV=production
APP_URL=https://example.com
APP_TRUSTED_HOSTS=example.com,www.example.com
APP_TRUST_REQUEST_HOST_FALLBACK=false
APP_DEBUG=false
APP_FORCE_HTTPS=true
APP_PROD_CONFIG_WARN_ONLY=false
APP_CSP_STRICT_NONCE=false
APP_CSP_ALLOW_UNSAFE_INLINE=true
APP_CSP_ALLOW_UNSAFE_INLINE_STYLES=true
APP_AUTO_SEED=false
APP_LOG_LEVEL=warning
TRUSTED_PROXIES=

ANALYTICS_RETENTION_DAYS=14
ANALYTICS_MAX_PAYLOAD_BYTES=16384

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mod2
DB_USERNAME=mod2_user
DB_PASSWORD=replace-with-a-strong-password
CORE_CACHE_BACKEND=file
CORE_CACHE_TABLE=core_cache
CORE_RATE_LIMIT_BACKEND=database
CORE_RATE_LIMIT_TABLE=request_rate_limits
CORE_RATE_LIMIT_SCOPE=default

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=core-cache

CDN_BASE_URL=

OPCACHE_RESET_TOKEN=
OPCACHE_RESET_ALLOWED_IPS=127.0.0.1
