# ---- Uygulama ayari ornegi ----
# Bu dosyayi `.env` olarak kopyalayin ve degerleri kendi ortaminiza gore duzenleyin.
# .env git tarafindan gormezden gelinir (bkz. .gitignore).
# Uretim icin .env.production.example sablonunu kullanin.

APP_INSTALLED=false
APP_NAME="Mod Portal"
APP_ENV=development
APP_URL="http://localhost/yenidosyalar"
APP_DEBUG=true
APP_FORCE_HTTPS=false
APP_CSP_REPORT_ONLY=true
APP_CSP_REPORT_URI=
APP_AUTO_SEED=false
APP_LOG_LEVEL=warning
TRUSTED_PROXIES=

ANALYTICS_RETENTION_DAYS=14
ANALYTICS_MAX_PAYLOAD_BYTES=16384

DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="turkmod"
DB_USERNAME="root"
DB_PASSWORD=""

CORE_CACHE_BACKEND=file
CORE_CACHE_TABLE=core_cache

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=core-cache

CDN_BASE_URL=

OPCACHE_RESET_TOKEN=
OPCACHE_RESET_ALLOWED_IPS=127.0.0.1
