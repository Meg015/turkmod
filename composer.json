{
    "name": "anomaly/mod-portal",
    "description": "Mod Portal / Icerik Topic - custom PHP CMS with modular OOP core, TPL theme engine and procedural legacy helpers.",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-ctype": "*",
        "ext-tokenizer": "*",
        "ext-redis": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6.34"
    },
    "autoload": {
        "psr-4": {
            "App\\": "includes/src/",
            "Tests\\": "tests/"
        },
        "classmap": [
            "includes/Database.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    },
    "scripts": {
        "test": "@php vendor/phpunit/phpunit/phpunit -c phpunit.xml",
        "lint": "@php tools/lint.php",
        "guard:migration:auto": "@php scripts/guard/migration_autogen.php --cached --stage",
        "guard:migration": "@php scripts/guard/migration_guard.php --cached",
        "guard:migration:workspace": "@php scripts/guard/migration_guard.php"
    }
}
