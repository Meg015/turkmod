<!doctype html>
<html lang="{site_language}" data-theme-mode="{theme_mode}" data-public-theme="{theme_id}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{page_title} - {site_name}</title>
  {head}
  <link rel="stylesheet" href="{theme_url}/assets/theme.css">
</head>
<body class="{body_class}">
  {header}
  <main id="content" class="ui-theme-theme-page ui-theme-theme-page-{page_key}">
    {content}
  </main>
  {footer}
  {scripts}
</body>
</html>
