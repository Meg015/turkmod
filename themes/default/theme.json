{
  "id": "default",
  "name": "TurkMod Default",
  "version": "1.0.0",
  "author": "TurkMod",
  "description": "Default user-facing theme package and fallback contract.",
  "engine": "turkmod-tpl",
  "engine_version": "1.0",
  "supports": {
    "color_modes": ["light", "dark", "auto"],
    "responsive": true,
    "rtl": false
  },
  "assets": {
    "css": ["assets/theme.css"],
    "js": ["assets/theme.js"],
    "preview": "assets/preview.svg"
  },
  "templates": {
    "layout": "layout.tpl",
    "header": "header.tpl",
    "footer": "footer.tpl",
    "home": "home.tpl",
    "category": "category.tpl",
    "search": "search.tpl",
    "topic": "topic.tpl",
    "download": "download.tpl",
    "profile": "profile.tpl",
    "public_profile": "public-profile.tpl",
    "login": "login.tpl",
    "register": "register.tpl",
    "forgot_password": "forgot-password.tpl",
    "reset_password": "reset-password.tpl",
    "upload_topic": "upload-topic.tpl",
    "edit_topic": "edit-topic.tpl",
    "contact": "contact.tpl",
    "notifications": "notifications.tpl",
    "leaderboard": "leaderboard.tpl",
    "ban_appeals": "ban-appeals.tpl",
    "events": {
      "index": "events/index.tpl",
      "wheel": "events/wheel.tpl",
      "raffle": "events/raffle.tpl",
      "rewards": "events/rewards.tpl",
      "tasks": "events/tasks.tpl"
    },
    "not_found": "404.tpl",
    "maintenance": "maintenance.tpl",
    "empty_state": "empty-state.tpl",
    "partials": {
      "topic_card": "partials/topic-card.tpl",
      "pagination": "partials/pagination.tpl",
      "user_menu": "partials/user-menu.tpl",
      "breadcrumb": "partials/breadcrumb.tpl",
      "alert": "partials/alert.tpl"
    }
  },
  "variables": {
    "required": ["site_name", "base_url", "page_title", "content"],
    "raw_slots": ["head", "content", "header", "footer", "scripts", "items_html", "form_html"]
  },
  "conversion": {
    "source": "turkmod",
    "dle_aliases": true
  }
}
